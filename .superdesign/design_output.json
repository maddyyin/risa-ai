{
  "draftId": "e235c7a5-791f-433d-b819-25c4f6f896a4",
  "title": "RISA - Responsive Dashboard",
  "htmlContent": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>RISA - AI Productivity Dashboard</title>\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n  <script src=\"https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js\"></script>\n  <link href=\"https://api.fontshare.com/v2/css?f[]=general-sans@400,500,600,700&f[]=cabinet-grotesk@700,800&display=swap\" rel=\"stylesheet\">\n  <style>\n    * { font-family: 'General Sans', sans-serif; }\n    .font-display { font-family: 'Cabinet Grotesk', sans-serif; }\n    \n    :root {\n      --glass-bg: rgba(255, 255, 255, 0.04);\n      --glass-border: rgba(255, 255, 255, 0.08);\n      --glow-purple: rgba(139, 92, 246, 0.3);\n      --glow-pink: rgba(236, 72, 153, 0.3);\n    }\n    \n    .glass-card {\n      background: var(--glass-bg);\n      backdrop-filter: blur(20px);\n      -webkit-backdrop-filter: blur(20px);\n      border: 1px solid var(--glass-border);\n      transition: all 0.3s ease;\n    }\n    \n    .glass-card:hover {\n      background: rgba(255, 255, 255, 0.07);\n      border-color: rgba(255, 255, 255, 0.15);\n      box-shadow: 0 8px 32px rgba(139, 92, 246, 0.12);\n      transform: translateY(-2px);\n    }\n    \n    .gradient-text {\n      background: linear-gradient(135deg, #818cf8 0%, #a78bfa 50%, #f472b6 100%);\n      -webkit-background-clip: text;\n      -webkit-text-fill-color: transparent;\n      background-clip: text;\n    }\n    \n    .glow-button {\n      background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 50%, #a855f7 100%);\n      box-shadow: 0 4px 20px rgba(139, 92, 246, 0.4);\n      transition: all 0.3s ease;\n    }\n    \n    .glow-button:hover {\n      box-shadow: 0 8px 40px rgba(139, 92, 246, 0.6);\n      transform: translateY(-2px);\n    }\n    \n    .sidebar-link {\n      transition: all 0.2s ease;\n    }\n    \n    .sidebar-link:hover {\n      background: rgba(139, 92, 246, 0.1);\n    }\n    \n    .sidebar-link.active {\n      background: rgba(139, 92, 246, 0.2);\n      border-right: 3px solid #8b5cf6;\n    }\n    \n    .progress-ring { transform: rotate(-90deg); }\n    \n    .progress-ring-circle {\n      stroke-dasharray: 283;\n      stroke-dashoffset: 283;\n      animation: progress-fill 2s ease-out forwards 0.5s;\n    }\n    \n    @keyframes progress-fill { to { stroke-dashoffset: 62; } }\n    \n    @keyframes fade-in-up {\n      from { opacity: 0; transform: translateY(20px); }\n      to { opacity: 1; transform: translateY(0); }\n    }\n    \n    @keyframes fade-in {\n      from { opacity: 0; }\n      to { opacity: 1; }\n    }\n    \n    @keyframes slide-in-left {\n      from { opacity: 0; transform: translateX(-20px); }\n      to { opacity: 1; transform: translateX(0); }\n    }\n    \n    @keyframes pulse-glow {\n      0%, 100% { opacity: 0.6; }\n      50% { opacity: 1; }\n    }\n    \n    @keyframes counter-up {\n      from { opacity: 0; transform: scale(0.8); }\n      to { opacity: 1; transform: scale(1); }\n    }\n    \n    @keyframes bar-grow {\n      from { transform: scaleY(0); }\n      to { transform: scaleY(1); }\n    }\n    \n    .animate-fade-in-up { animation: fade-in-up 0.6s ease-out forwards; opacity: 0; }\n    .animate-fade-in { animation: fade-in 0.8s ease-out forwards; opacity: 0; }\n    .animate-slide-left { animation: slide-in-left 0.5s ease-out forwards; opacity: 0; }\n    .animate-counter { animation: counter-up 0.8s ease-out forwards; opacity: 0; }\n    .animate-bar { animation: bar-grow 0.8s ease-out forwards; transform-origin: bottom; }\n    .ai-pulse { animation: pulse-glow 2s ease-in-out infinite; }\n    \n    .delay-100 { animation-delay: 0.1s; }\n    .delay-200 { animation-delay: 0.2s; }\n    .delay-300 { animation-delay: 0.3s; }\n    .delay-400 { animation-delay: 0.4s; }\n    .delay-500 { animation-delay: 0.5s; }\n    .delay-600 { animation-delay: 0.6s; }\n    .delay-700 { animation-delay: 0.7s; }\n    .delay-800 { animation-delay: 0.8s; }\n    \n    .time-block-morning { border-left: 3px solid #fbbf24; }\n    .time-block-afternoon { border-left: 3px solid #f97316; }\n    .time-block-evening { border-left: 3px solid #8b5cf6; }\n    \n    .bar-tooltip {\n      opacity: 0;\n      transition: opacity 0.2s ease;\n      pointer-events: none;\n    }\n    \n    .bar-container:hover .bar-tooltip { opacity: 1; }\n    .bar-container:hover .bar-fill { filter: brightness(1.2); }\n    \n    ::-webkit-scrollbar { width: 6px; }\n    ::-webkit-scrollbar-track { background: rgba(255, 255, 255, 0.02); }\n    ::-webkit-scrollbar-thumb { background: rgba(139, 92, 246, 0.4); border-radius: 4px; }\n    ::-webkit-scrollbar-thumb:hover { background: rgba(139, 92, 246, 0.6); }\n  </style>\n</head>\n<body>\n  <div class=\"min-h-screen flex bg-[#0a0a14] text-white\">\n    \n    <!-- Ambient Background Effects -->\n    <div class=\"fixed inset-0 pointer-events-none overflow-hidden\">\n      <div class=\"absolute top-[-200px] right-[-200px] w-[600px] h-[600px] rounded-full bg-purple-600/8 blur-[150px]\"></div>\n      <div class=\"absolute bottom-[-150px] left-[-150px] w-[500px] h-[500px] rounded-full bg-indigo-600/8 blur-[120px]\"></div>\n      <div class=\"absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[400px] h-[400px] rounded-full bg-pink-600/5 blur-[100px]\"></div>\n    </div>\n    \n    <!-- Sidebar - Desktop -->\n    <aside class=\"hidden lg:flex flex-col w-72 border-r border-white/5 bg-[#0a0a14]/80 backdrop-blur-xl relative z-20\">\n      <!-- Logo -->\n      <div class=\"p-6 border-b border-white/5 animate-slide-left\">\n        <div class=\"flex items-center gap-3\">\n          <div class=\"w-11 h-11 rounded-xl bg-gradient-to-br from-indigo-500 via-purple-500 to-pink-500 flex items-center justify-center\">\n            <iconify-icon icon=\"lucide:sparkles\" class=\"text-white text-xl\"></iconify-icon>\n          </div>\n          <div>\n            <span class=\"font-display font-bold text-xl tracking-tight\">RISA</span>\n            <p class=\"text-white/40 text-xs -mt-0.5\">Intelligent Assistant</p>\n          </div>\n        </div>\n      </div>\n      \n      <!-- Navigation -->\n      <nav class=\"flex-1 p-4 space-y-1\">\n        <a href=\"#\" id=\"sidebar-dashboard-link\" class=\"sidebar-link active flex items-center gap-3 px-4 py-3 rounded-xl text-white\">\n          <iconify-icon icon=\"lucide:layout-dashboard\" class=\"text-xl text-purple-400\"></iconify-icon>\n          <span class=\"font-medium\">Dashboard</span>\n        </a>\n        <a href=\"#\" id=\"sidebar-tasks-link\" class=\"sidebar-link flex items-center gap-3 px-4 py-3 rounded-xl text-white/60 hover:text-white\">\n          <iconify-icon icon=\"lucide:check-square\" class=\"text-xl\"></iconify-icon>\n          <span class=\"font-medium\">Tasks</span>\n          <span class=\"ml-auto px-2 py-0.5 rounded-md bg-purple-500/20 text-purple-400 text-xs font-medium\">18</span>\n        </a>\n        <a href=\"#\" id=\"sidebar-planner-link\" class=\"sidebar-link flex items-center gap-3 px-4 py-3 rounded-xl text-white/60 hover:text-white\">\n          <iconify-icon icon=\"lucide:calendar\" class=\"text-xl\"></iconify-icon>\n          <span class=\"font-medium\">Planner</span>\n        </a>\n        <a href=\"#\" id=\"sidebar-analytics-link\" class=\"sidebar-link flex items-center gap-3 px-4 py-3 rounded-xl text-white/60 hover:text-white\">\n          <iconify-icon icon=\"lucide:bar-chart-3\" class=\"text-xl\"></iconify-icon>\n          <span class=\"font-medium\">Analytics</span>\n        </a>\n        <a href=\"#\" id=\"sidebar-settings-link\" class=\"sidebar-link flex items-center gap-3 px-4 py-3 rounded-xl text-white/60 hover:text-white\">\n          <iconify-icon icon=\"lucide:settings\" class=\"text-xl\"></iconify-icon>\n          <span class=\"font-medium\">Settings</span>\n        </a>\n      </nav>\n      \n      <!-- AI Assistant Card -->\n      <div class=\"p-4\">\n        <div class=\"glass-card rounded-2xl p-4 border-purple-500/20\">\n          <div class=\"flex items-center gap-3 mb-3\">\n            <div class=\"w-10 h-10 rounded-xl bg-gradient-to-br from-indigo-500 to-purple-500 flex items-center justify-center\">\n              <iconify-icon icon=\"lucide:brain\" class=\"text-white text-lg ai-pulse\"></iconify-icon>\n            </div>\n            <div>\n              <h4 class=\"font-semibold text-sm text-white\">AI Ready</h4>\n              <p class=\"text-white/40 text-xs\">Auto-scheduling on</p>\n            </div>\n          </div>\n          <button id=\"ai-schedule-btn\" class=\"w-full glow-button rounded-xl py-2.5 text-sm font-semibold text-white\">\n            AI Auto-Schedule\n          </button>\n        </div>\n      </div>\n      \n      <!-- User Profile -->\n      <div class=\"p-4 border-t border-white/5\">\n        <div class=\"flex items-center gap-3\">\n          <div class=\"w-10 h-10 rounded-xl bg-gradient-to-br from-amber-400 to-orange-500 flex items-center justify-center font-semibold text-sm\">\n            JD\n          </div>\n          <div class=\"flex-1 min-w-0\">\n            <p class=\"font-medium text-sm text-white truncate\">John Doe</p>\n            <p class=\"text-white/40 text-xs truncate\">john@example.com</p>\n          </div>\n          <button id=\"user-menu-btn\" class=\"w-8 h-8 rounded-lg hover:bg-white/5 flex items-center justify-center transition-colors\">\n            <iconify-icon icon=\"lucide:more-vertical\" class=\"text-white/40\"></iconify-icon>\n          </button>\n        </div>\n      </div>\n    </aside>\n    \n    <!-- Main Content -->\n    <div class=\"flex-1 flex flex-col min-h-screen relative z-10\">\n      \n      <!-- Top Header -->\n      <header class=\"shrink-0 px-6 lg:px-8 py-4 lg:py-5 border-b border-white/5 bg-[#0a0a14]/60 backdrop-blur-xl\">\n        <div class=\"flex items-center justify-between animate-fade-in\">\n          <!-- Mobile Logo -->\n          <div class=\"flex lg:hidden items-center gap-2\">\n            <div class=\"w-9 h-9 rounded-xl bg-gradient-to-br from-indigo-500 via-purple-500 to-pink-500 flex items-center justify-center\">\n              <iconify-icon icon=\"lucide:sparkles\" class=\"text-white text-lg\"></iconify-icon>\n            </div>\n            <span class=\"font-display font-bold text-xl tracking-tight\">RISA</span>\n          </div>\n          \n          <!-- Greeting & Date - Desktop -->\n          <div class=\"hidden lg:block\">\n            <h1 class=\"font-display font-bold text-2xl tracking-tight\">Good Morning, John</h1>\n            <p class=\"text-white/40 text-sm\">Tuesday, 17 June 2025</p>\n          </div>\n          \n          <!-- Actions -->\n          <div class=\"flex items-center gap-3\">\n            <!-- Search - Desktop -->\n            <div class=\"hidden lg:flex items-center gap-2 px-4 py-2.5 rounded-xl glass-card w-64\">\n              <iconify-icon icon=\"lucide:search\" class=\"text-white/40\"></iconify-icon>\n              <input type=\"text\" placeholder=\"Search tasks...\" class=\"bg-transparent border-none outline-none text-sm text-white placeholder-white/40 w-full\">\n              <span class=\"text-white/20 text-xs border border-white/10 rounded px-1.5 py-0.5\">ΓîÿK</span>\n            </div>\n            \n            <button id=\"nav-notifications-btn\" class=\"relative w-10 h-10 glass-card rounded-xl flex items-center justify-center\">\n              <iconify-icon icon=\"lucide:bell\" class=\"text-lg text-white/70\"></iconify-icon>\n              <span class=\"absolute top-1 right-1 w-2 h-2 bg-pink-500 rounded-full\"></span>\n            </button>\n            \n            <!-- Mobile Menu -->\n            <button id=\"mobile-menu-btn\" class=\"lg:hidden w-10 h-10 glass-card rounded-xl flex items-center justify-center\">\n              <iconify-icon icon=\"lucide:menu\" class=\"text-lg text-white/70\"></iconify-icon>\n            </button>\n            \n            <!-- Profile - Desktop -->\n            <div class=\"hidden lg:flex items-center gap-3 pl-3 border-l border-white/10\">\n              <div class=\"w-10 h-10 rounded-xl bg-gradient-to-br from-amber-400 to-orange-500 flex items-center justify-center font-semibold text-sm\">\n                JD\n              </div>\n            </div>\n          </div>\n        </div>\n        \n        <!-- Mobile Greeting -->\n        <div class=\"lg:hidden mt-4 animate-fade-in-up delay-100\">\n          <p class=\"text-white/40 text-sm\">Tuesday, 17 June 2025</p>\n          <h1 class=\"font-display font-bold text-xl tracking-tight\">Good Morning, John</h1>\n        </div>\n      </header>\n      \n      <!-- Scrollable Content -->\n      <main class=\"flex-1 overflow-y-auto p-6 lg:p-8\">\n        <div class=\"max-w-7xl mx-auto\">\n          \n          <!-- Stats Grid - Top Row -->\n          <div class=\"grid grid-cols-1 lg:grid-cols-3 gap-4 lg:gap-6 mb-6\">\n            \n            <!-- Productivity Score Card -->\n            <div class=\"lg:col-span-2 glass-card rounded-3xl p-6 animate-fade-in-up delay-200\">\n              <div class=\"flex flex-col lg:flex-row lg:items-center justify-between gap-6\">\n                <div class=\"flex-1\">\n                  <div class=\"flex items-center gap-2 mb-3\">\n                    <iconify-icon icon=\"lucide:zap\" class=\"text-amber-400 text-xl\"></iconify-icon>\n                    <span class=\"text-white/60 text-sm font-medium\">Productivity Score</span>\n                  </div>\n                  <div class=\"flex items-baseline gap-2 mb-4\">\n                    <span class=\"font-display font-bold text-6xl lg:text-7xl gradient-text animate-counter delay-500\">78</span>\n                    <span class=\"text-white/40 text-2xl\">%</span>\n                  </div>\n                  <div class=\"flex items-center gap-3\">\n                    <span class=\"inline-flex items-center gap-1 px-3 py-1.5 rounded-xl bg-emerald-500/20 text-emerald-400 text-sm font-medium\">\n                      <iconify-icon icon=\"lucide:trending-up\" class=\"text-base\"></iconify-icon>\n                      +12%\n                    </span>\n                    <span class=\"text-white/40 text-sm\">vs last week</span>\n                  </div>\n                </div>\n                \n                <!-- Circular Progress -->\n                <div class=\"relative w-32 h-32 lg:w-36 lg:h-36 mx-auto lg:mx-0\">\n                  <svg class=\"progress-ring w-full h-full\" viewBox=\"0 0 100 100\">\n                    <circle cx=\"50\" cy=\"50\" r=\"45\" stroke=\"rgba(255,255,255,0.08)\" stroke-width=\"8\" fill=\"none\"/>\n                    <circle class=\"progress-ring-circle\" cx=\"50\" cy=\"50\" r=\"45\" stroke=\"url(#gradient)\" stroke-width=\"8\" fill=\"none\" stroke-linecap=\"round\"/>\n                    <defs>\n                      <linearGradient id=\"gradient\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"100%\">\n                        <stop offset=\"0%\" stop-color=\"#6366f1\"/>\n                        <stop offset=\"50%\" stop-color=\"#8b5cf6\"/>\n                        <stop offset=\"100%\" stop-color=\"#ec4899\"/>\n                      </linearGradient>\n                    </defs>\n                  </svg>\n                  <div class=\"absolute inset-0 flex items-center justify-center\">\n                    <div class=\"w-16 h-16 rounded-2xl bg-gradient-to-br from-indigo-500/20 to-purple-500/20 flex items-center justify-center\">\n                      <iconify-icon icon=\"lucide:brain\" class=\"text-3xl text-purple-400 ai-pulse\"></iconify-icon>\n                    </div>\n                  </div>\n                </div>\n              </div>\n            </div>\n            \n            <!-- Quick Stats -->\n            <div class=\"space-y-4 lg:space-y-6\">\n              <!-- Tasks Completed -->\n              <div class=\"glass-card rounded-2xl p-5 animate-fade-in-up delay-300\">\n                <div class=\"flex items-center gap-3 mb-3\">\n                  <div class=\"w-10 h-10 rounded-xl bg-emerald-500/20 flex items-center justify-center\">\n                    <iconify-icon icon=\"lucide:check-circle-2\" class=\"text-emerald-400 text-lg\"></iconify-icon>\n                  </div>\n                  <span class=\"text-white/50 text-sm\">Tasks Done</span>\n                </div>\n                <div class=\"flex items-baseline gap-2\">\n                  <span class=\"font-display font-bold text-3xl text-white\">12</span>\n                  <span class=\"text-white/40 text-lg\">/18</span>\n                </div>\n                <div class=\"mt-3 h-2 rounded-full bg-white/10 overflow-hidden\">\n                  <div class=\"h-full w-[67%] rounded-full bg-gradient-to-r from-emerald-500 to-cyan-400\"></div>\n                </div>\n              </div>\n              \n              <!-- Focus Time -->\n              <div class=\"glass-card rounded-2xl p-5 animate-fade-in-up delay-400\">\n                <div class=\"flex items-center gap-3 mb-3\">\n                  <div class=\"w-10 h-10 rounded-xl bg-amber-500/20 flex items-center justify-center\">\n                    <iconify-icon icon=\"lucide:timer\" class=\"text-amber-400 text-lg\"></iconify-icon>\n                  </div>\n                  <span class=\"text-white/50 text-sm\">Focus Time</span>\n                </div>\n                <div class=\"flex items-baseline gap-2\">\n                  <span class=\"font-display font-bold text-3xl text-white\">4.5</span>\n                  <span class=\"text-white/40 text-lg\">hrs</span>\n                </div>\n                <p class=\"text-white/30 text-xs mt-2\">Goal: 6 hrs daily</p>\n              </div>\n            </div>\n          </div>\n          \n          <!-- Main Content Grid -->\n          <div class=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\n            \n            <!-- Left Column - Schedule & Tasks -->\n            <div class=\"lg:col-span-2 space-y-6\">\n              \n              <!-- Today's Schedule -->\n              <div class=\"animate-fade-in-up delay-500\">\n                <div class=\"flex items-center justify-between mb-4\">\n                  <h2 class=\"font-semibold text-lg text-white\">Today's Schedule</h2>\n                  <a href=\"#\" id=\"view-planner-link\" class=\"text-purple-400 text-sm font-medium flex items-center gap-1 hover:text-purple-300 transition-colors\">\n                    View Planner\n                    <iconify-icon icon=\"lucide:chevron-right\" class=\"text-sm\"></iconify-icon>\n                  </a>\n                </div>\n                \n                <div class=\"grid grid-cols-1 md:grid-cols-3 gap-4\">\n                  <!-- Morning -->\n                  <div class=\"glass-card rounded-2xl p-4 time-block-morning\">\n                    <div class=\"flex items-center gap-3 mb-4\">\n                      <div class=\"w-10 h-10 rounded-xl bg-amber-500/20 flex items-center justify-center\">\n                        <iconify-icon icon=\"lucide:sunrise\" class=\"text-amber-400 text-lg\"></iconify-icon>\n                      </div>\n                      <div>\n                        <h3 class=\"font-semibold text-white text-sm\">Morning</h3>\n                        <p class=\"text-white/40 text-xs\">6 AM - 12 PM</p>\n                      </div>\n                    </div>\n                    <div class=\"space-y-2\">\n                      <div class=\"flex items-center gap-2 p-2 rounded-lg bg-white/5\">\n                        <div class=\"w-1.5 h-1.5 rounded-full bg-emerald-400\"></div>\n                        <span class=\"text-white/70 text-xs truncate\">Review PRs</span>\n                        <span class=\"ml-auto text-white/30 text-xs\">30m</span>\n                      </div>\n                      <div class=\"flex items-center gap-2 p-2 rounded-lg bg-white/5\">\n                        <div class=\"w-1.5 h-1.5 rounded-full bg-emerald-400\"></div>\n                        <span class=\"text-white/70 text-xs truncate\">Standup</span>\n                        <span class=\"ml-auto text-white/30 text-xs\">15m</span>\n                      </div>\n                      <div class=\"flex items-center gap-2 p-2 rounded-lg bg-white/5\">\n                        <div class=\"w-1.5 h-1.5 rounded-full bg-white/30\"></div>\n                        <span class=\"text-white/70 text-xs truncate\">Feature dev</span>\n                        <span class=\"ml-auto text-white/30 text-xs\">2h</span>\n                      </div>\n                    </div>\n                    <p class=\"text-center text-white/30 text-xs mt-3\">+1 more task</p>\n                  </div>\n                  \n                  <!-- Afternoon -->\n                  <div class=\"glass-card rounded-2xl p-4 time-block-afternoon\">\n                    <div class=\"flex items-center gap-3 mb-4\">\n                      <div class=\"w-10 h-10 rounded-xl bg-orange-500/20 flex items-center justify-center\">\n                        <iconify-icon icon=\"lucide:sun\" class=\"text-orange-400 text-lg\"></iconify-icon>\n                      </div>\n                      <div>\n                        <h3 class=\"font-semibold text-white text-sm\">Afternoon</h3>\n                        <p class=\"text-white/40 text-xs\">12 PM - 6 PM</p>\n                      </div>\n                    </div>\n                    <div class=\"space-y-2\">\n                      <div class=\"flex items-center gap-2 p-2 rounded-lg bg-white/5\">\n                        <div class=\"w-1.5 h-1.5 rounded-full bg-amber-400\"></div>\n                        <span class=\"text-white/70 text-xs truncate\">Design Review</span>\n                        <span class=\"ml-auto text-white/30 text-xs\">1h</span>\n                      </div>\n                      <div class=\"flex items-center gap-2 p-2 rounded-lg bg-white/5\">\n                        <div class=\"w-1.5 h-1.5 rounded-full bg-white/30\"></div>\n                        <span class=\"text-white/70 text-xs truncate\">API Integration</span>\n                        <span class=\"ml-auto text-white/30 text-xs\">2h</span>\n                      </div>\n                      <div class=\"flex items-center gap-2 p-2 rounded-lg bg-white/5\">\n                        <div class=\"w-1.5 h-1.5 rounded-full bg-white/30\"></div>\n                        <span class=\"text-white/70 text-xs truncate\">Client Call</span>\n                        <span class=\"ml-auto text-white/30 text-xs\">30m</span>\n                      </div>\n                    </div>\n                    <p class=\"text-center text-white/30 text-xs mt-3\">+3 more tasks</p>\n                  </div>\n                  \n                  <!-- Evening -->\n                  <div class=\"glass-card rounded-2xl p-4 time-block-evening\">\n                    <div class=\"flex items-center gap-3 mb-4\">\n                      <div class=\"w-10 h-10 rounded-xl bg-purple-500/20 flex items-center justify-center\">\n                        <iconify-icon icon=\"lucide:moon\" class=\"text-purple-400 text-lg\"></iconify-icon>\n                      </div>\n                      <div>\n                        <h3 class=\"font-semibold text-white text-sm\">Evening</h3>\n                        <p class=\"text-white/40 text-xs\">6 PM - 10 PM</p>\n                      </div>\n                    </div>\n                    <div class=\"space-y-2\">\n                      <div class=\"flex items-center gap-2 p-2 rounded-lg bg-white/5\">\n                        <div class=\"w-1.5 h-1.5 rounded-full bg-white/30\"></div>\n                        <span class=\"text-white/70 text-xs truncate\">Documentation</span>\n                        <span class=\"ml-auto text-white/30 text-xs\">1h</span>\n                      </div>\n                      <div class=\"flex items-center gap-2 p-2 rounded-lg bg-white/5\">\n                        <div class=\"w-1.5 h-1.5 rounded-full bg-white/30\"></div>\n                        <span class=\"text-white/70 text-xs truncate\">Planning</span>\n                        <span class=\"ml-auto text-white/30 text-xs\">45m</span>\n                      </div>\n                    </div>\n                    <p class=\"text-center text-white/40 text-xs mt-3\">Light schedule</p>\n                  </div>\n                </div>\n              </div>\n              \n              <!-- Weekly Productivity Chart -->\n              <div class=\"glass-card rounded-3xl p-6 animate-fade-in-up delay-600\">\n                <div class=\"flex items-center justify-between mb-6\">\n                  <div>\n                    <h3 class=\"font-semibold text-lg text-white\">Weekly Productivity</h3>\n                    <p class=\"text-white/40 text-sm\">Tasks completed per day</p>\n                  </div>\n                  <span class=\"flex items-center gap-1 px-3 py-1.5 rounded-xl bg-emerald-500/20 text-emerald-400 text-sm font-medium\">\n                    <iconify-icon icon=\"lucide:trending-up\" class=\"text-sm\"></iconify-icon>\n                    +23%\n                  </span>\n                </div>\n                \n                <!-- Bar Chart -->\n                <div class=\"relative h-48\">\n                  <div class=\"absolute inset-0 flex flex-col justify-between pointer-events-none\">\n                    <div class=\"border-b border-white/5 flex items-center\"><span class=\"text-xs text-white/25 w-8\">20</span></div>\n                    <div class=\"border-b border-white/5 flex items-center\"><span class=\"text-xs text-white/25 w-8\">15</span></div>\n                    <div class=\"border-b border-white/5 flex items-center\"><span class=\"text-xs text-white/25 w-8\">10</span></div>\n                    <div class=\"border-b border-white/5 flex items-center\"><spa